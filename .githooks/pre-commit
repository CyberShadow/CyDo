#!/usr/bin/env bash
#
# Pre-commit hook: verify that `nix flake check` has passed for the
# exact tree being committed.
#
# How it works:
#   1. Creates an ephemeral commit from the index (no ref/worktree mutation)
#   2. Evaluates nix to get derivation paths for that tree
#   3. Uses nix-store --realise --dry-run to check if all outputs are
#      available (locally or via substituter)
#
# If any check output needs to be built, the commit is rejected with a message
# to run `nix flake check` first.

set -euo pipefail

# Create ephemeral commit from the index
TREE=$(git write-tree)
COMMIT=$(git commit-tree "$TREE" -m 'pre-commit check')

# Get system architecture
SYSTEM=$(nix eval --raw --impure --expr 'builtins.currentSystem')

# Evaluate derivation paths (no building, just evaluation ~2s)
DRVS=$(nix eval ".?rev=$COMMIT#checks.$SYSTEM" \
  --apply 'builtins.mapAttrs (_: c: c.drvPath)' --json 2>/dev/null) || {
  echo "error: could not evaluate flake checks"
  exit 1
}

# Collect all drv paths
DRV_PATHS=()
while IFS= read -r path; do
  DRV_PATHS+=("$path")
done < <(echo "$DRVS" | jq -r '.[]')

if [[ ${#DRV_PATHS[@]} -eq 0 ]]; then
  echo "error: no flake checks found"
  exit 1
fi

# nix-store --realise --dry-run checks availability without building:
#   - paths in local store: no output
#   - paths on a substituter: "will be fetched"
#   - paths not built anywhere: "will be built" (drv paths in output)
DRY_OUTPUT=$(nix-store --realise --dry-run "${DRV_PATHS[@]}" 2>&1)

# .drv paths in the output indicate derivations that need building
NEEDS_BUILD=$(echo "$DRY_OUTPUT" | grep '\.drv$' || true)
if [[ -n "$NEEDS_BUILD" ]]; then
  echo "nix flake check has not passed for this tree."
  echo ""
  echo "Run:"
  echo "  nix flake check"
  echo ""
  echo "Derivations that need building:"
  echo "$NEEDS_BUILD" | sed 's/^/  /'
  exit 1
fi
