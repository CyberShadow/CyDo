{
  "name": "cydo-web",
  "private": true,
  "scripts": {
    "generate": "cd .. && dub run cydo:protocol-codegen -- web/src/generated/protocol.ts",
    "build": "vite build",
    "build:export": "vite build --config vite.export.config.ts",
    "dev": "vite",
    "fmt": "prettier --write src/",
    "fmt:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@incremark/core": "^0.3.10",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "htmldiff-js": "^1.0.5",
    "marked": "^17.0.3",
    "mermaid": "^11.13.0",
    "preact": "^10.25.4",
    "preact-iso": "^2.11.1",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.3",
    "@types/dompurify": "^3.0.5",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.3"
  }
}
